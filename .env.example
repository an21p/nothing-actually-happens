# Optional: Polygon RPC endpoint for on-chain data enrichment
# Default: https://polygon-rpc.com (public, rate-limited)
POLYGON_RPC_URL=https://polygon-rpc.com

# --- Live paper-trading bot ---
LIVE_CATEGORIES=geopolitical,political,culture
LIVE_SIZING_RULE=fixed_notional      # fixed_notional | fixed_shares | kelly
LIVE_SIZING_NOTIONAL=100
LIVE_SIZING_SHARES=100
LIVE_SIZING_KELLY_WIN_RATE=0.75
LIVE_SIZING_KELLY_FRACTION=0.25
LIVE_BANKROLL_START=10000
LIVE_MAX_OPEN_POSITIONS=50
LIVE_EXECUTOR=paper                  # paper | live (live not implemented)
LIVE_MAX_AGE_HOURS=24
LIVE_TOLERANCE_HOURS=12

# --- Telegram notifications (optional — absent → NullNotifier) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
